generator client {
  provider = "prisma-client"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model status_trail {
  trailId   Int                 @id @default(autoincrement())
  userId    String              @db.VarChar(6)
  status    status_trail_status
  timestamp DateTime            @db.DateTime(0)
  source    status_trail_source
  user      user                @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "status_trail_ibfk_1")

  @@index([userId], map: "userId")
}

model user {
  id             String             @id @db.VarChar(6)
  name           String             @db.VarChar(255)
  collegeName    String             @db.VarChar(255)
  email          String             @unique(map: "email") @db.VarChar(255)
  phoneNumber    String             @db.VarChar(20)
  visitDates     String             @db.Text
  currentStatus  user_currentStatus @default(gate_out)
  lastStatusTime DateTime           @db.DateTime(0)
  festId         String // Foreign key to fest_user
  fest           fest_user          @relation(fields: [festId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  status_trail   status_trail[]
  user_event     user_event[]

  @@index([festId], map: "festId")
}

model user_event {
  userId    String    @db.VarChar(6)
  eventId   Int
  eventName String    @db.VarChar(255)
  festId    String // Foreign key to fest_user
  user      user      @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "user_event_ibfk_1")
  fest      fest_user @relation(fields: [festId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@id([userId, eventId])
  @@index([festId], map: "festId_event")
}

model fest_user {
  id         String       @id @default(cuid())
  username   String       @unique @db.VarChar(50)
  password   String       @db.VarChar(255)
  email      String       @unique @db.VarChar(255)
  role       String       @default("fest") @db.VarChar(20)
  createdAt  DateTime     @default(now()) @db.DateTime(0)
  updatedAt  DateTime     @updatedAt @db.DateTime(0)
  users      user[] // Relation to users
  user_event user_event[] // Relation to user_events
}

enum status_trail_status {
  gate_out @map("gate-out")
  gate_in  @map("gate-in")
  reg_in   @map("reg-in")
  reg_out  @map("reg-out")
}

enum status_trail_source {
  gate
  registration
  admin
  system
}

enum user_currentStatus {
  gate_out @map("gate-out")
  gate_in  @map("gate-in")
  reg_in   @map("reg-in")
  reg_out  @map("reg-out")
}
